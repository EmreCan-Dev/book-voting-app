@model List<BookViewModel>

<div class="table-responsive">
    <table class="table table-striped table-hover table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Başlık</th>
                <th>Yazar</th>
                <th>Kategori</th>
                <th>Puan</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in Model)
{
    <tr>
        <td>@book.Title</td>
        <td>@book.Author</td>
        <td>@book.Category</td>

        <td>
            <form asp-controller="User"
                  asp-action="RateBooks"
                  method="post"
                  class="d-flex">

                @Html.AntiForgeryToken()   <!-- güvenlik için -->

                <input type="hidden" name="bookId" value="@book.Id" />

                <select name="rating"
                        class="form-select me-2"
                        style="width: 90px;">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <option value="@i"
                                            selected="@(book.UserRating == i ? "selected" : null)">
                                        @(new string('★', i))
                                    </option>
                                }
                </select>

                <button type="submit"
                        class="btn btn-sm btn-primary">
                    Rate
                </button>
            </form>
        </td>
    </tr>
}
        </tbody>
    </table>
</div>




